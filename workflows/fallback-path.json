    },
    {
      "id": "c3d4e5f6-3333-4000-8000-000000000003",
      "name": "Primary OK?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [750, 300],
      "parameters": {
        "conditions": {
          "number": [
            {
              "value1": "={{ $json.statusCode || 200 }}",
              "operation": "smaller",
              "value2": 400
            }
          ]
        }
      }
    },
    {
      "id": "c3d4e5f6-3333-4000-8000-000000000004",
      "name": "Primary Success",
      "type": "n8n-nodes-base.set",
      "typeVersion": 4,
      "position": [1000, 200],
      "parameters": {
        "mode": "manual",
        "assignments": {
          "assignments": [
            {
              "id": "served-by",
              "name": "served_by",
              "value": "primary",
              "type": "string"
            },
            {
              "id": "degraded",
              "name": "degraded",
              "value": false,
              "type": "boolean"
            }
          ]
        },
        "options": {
          "includeBinary": false
        }
      }
    },
    {
      "id": "c3d4e5f6-3333-4000-8000-000000000005",
      "name": "Fallback Service Request",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 1,
      "position": [1000, 450],
      "parameters": {
        "url": "={{ $('Webhook Trigger').first().json.body.fallback_url || 'https://api.fallback-service.com/data' }}",
        "method": "={{ $('Webhook Trigger').first().json.body.method || 'GET' }}",
        "options": {
          "timeout": 5000
        }
      },
      "continueOnFail": true
    },
    {
      "id": "c3d4e5f6-3333-4000-8000-000000000006",
